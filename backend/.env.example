# Database Configuration (Cloud SQL)
DATABASE_URL=postgresql://user:password@localhost:5432/equipment_booking
# For Cloud SQL with Unix socket:
# DATABASE_URL=postgresql://user:password@/equipment_booking?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME

# Server Configuration
PORT=8080
NODE_ENV=development

# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
# For local development, set path to service account JSON
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# GCS Configuration
GCS_BUCKET_NAME=your-bucket-name

# CORS
CORS_ORIGIN=http://localhost:5173
